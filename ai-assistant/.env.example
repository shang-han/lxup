# ─── LXUP AI 助手配置 ───
# 复制本文件为 .env 后填写。也可用系统环境变量覆盖（环境变量优先）。

# LLM 服务 API Key（必填）。支持任意 OpenAI 兼容接口：DeepSeek / OpenAI / 本地 Ollama 等
API_KEY=sk-xxxx

# OpenAI 兼容接口基址（不含 /chat/completions）
#   DeepSeek : https://api.deepseek.com
#   OpenAI   : https://api.openai.com/v1
#   阿里百炼 : https://dashscope.aliyuncs.com/compatible-mode/v1
#   本地Ollama: http://localhost:11434/v1
BASE_URL=https://api.deepseek.com

# 模型名
MODEL=deepseek-chat

# 服务端口
PORT=8080

# 工具环最大轮次（一次对话中最多调用多少轮命令行工具）
MAX_TOOL_ROUNDS=10
